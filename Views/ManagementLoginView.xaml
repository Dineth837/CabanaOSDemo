<UserControl x:Class="CabanaOSDemo.Views.ManagementLoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9">

    <Grid Margin="15,0,15,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,10,0,15">
            <TextBlock Text="Cabana Management System" FontSize="24" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="1" Background="#0F172A" CornerRadius="20" Padding="30">
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center" Width="500">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Cabana Management System" FontSize="28" FontWeight="Bold" Foreground="#94A3B8" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Grid.Row="1" Text="Management Logging" FontSize="18" FontWeight="SemiBold" Foreground="#64748B" HorizontalAlignment="Center" Margin="0,0,0,40"/>

                <Grid Grid.Row="2" HorizontalAlignment="Center" Margin="0,0,0,35">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="220"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="User Name" FontSize="14" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center" Margin="0,0,0,20"/>
                    <TextBox x:Name="TxtUsername" Grid.Row="0" Grid.Column="1" Height="36" Background="#CBD5E1" Foreground="#1E293B" FontSize="14" FontWeight="Medium" VerticalContentAlignment="Center" Padding="12,0" BorderThickness="0" Margin="0,0,0,20">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="14"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Password" FontSize="14" FontWeight="Bold" Foreground="#94A3B8" VerticalAlignment="Center"/>
                    
                    <Border Grid.Row="1" Grid.Column="1" Height="36" Background="#CBD5E1" CornerRadius="14" BorderThickness="0">
                        <PasswordBox x:Name="TxtPassword" 
                                     Background="Transparent" 
                                     Foreground="#1E293B" 
                                     FontSize="14" 
                                     VerticalContentAlignment="Center" 
                                     Padding="8,0" 
                                     BorderThickness="0"/>
                    </Border>
                </Grid>

                <Button x:Name="BtnLogin" Grid.Row="3" Content="Log" Click="BtnLogin_Click" Width="100" Height="36" Background="#CBD5E1" Foreground="#1E293B" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center" Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="14"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>