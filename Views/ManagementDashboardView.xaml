<UserControl x:Class="CabanaOSDemo.Views.ManagementDashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:CabanaOSDemo.Views"
             Background="#EAF7F4">

    <Grid Margin="20,10,20,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,10,0,20">
            <TextBlock Text="📈 Management Dashboard" FontSize="26" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Create Report" Background="#1E293B" Foreground="White" FontWeight="Bold" FontSize="12" Padding="20,10" Margin="0,0,12,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="14"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Current User" Background="#D6E6E2" Foreground="#475569" FontWeight="Bold" FontSize="12" Padding="20,10">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="14"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="260"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="290"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                    <Border Background="White" CornerRadius="16" Height="70" Padding="20,10" Margin="0,0,0,10">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Total Sales From Suites" FontSize="14" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock x:Name="TxtSuiteSalesVal" Text="Rs. 0.00" FontSize="14" FontWeight="Bold" Foreground="#94A3B8" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="16" Height="70" Padding="20,10" Margin="0,0,0,10">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Total Sales From Restaurant" FontSize="14" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock x:Name="TxtRestaurantSalesVal" Text="Rs. 0.00" FontSize="14" FontWeight="Bold" Foreground="#94A3B8" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" CornerRadius="16" Height="70" Padding="20,10">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Total Combined Revenue" FontSize="14" FontWeight="Bold" Foreground="#1E293B"/>
                            <TextBlock x:Name="TxtCombinedRevenueVal" Text="Rs. 0.00" FontSize="14" FontWeight="Bold" Foreground="#94A3B8" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1" Background="White" CornerRadius="20" Margin="10,0,6,0" Padding="15">
                    <local:CabanaSuitesSalesPieChart x:Name="SuitesPieChartCtrl" Loaded="SuitesPieChartCtrl_Loaded"/>
                </Border>

                <Border Grid.Column="2" Background="White" CornerRadius="20" Margin="6,0,0,0" Padding="15">
                    <local:RestaurantSalesPieChart x:Name="RestaurantPieChartCtrl" Loaded="RestaurantPieChartCtrl_Loaded"/>
                </Border>
            </Grid>

            <Border Grid.Row="1" Background="White" CornerRadius="24">
                <local:MonthlySalesBarChart x:Name="MonthlyBarChartCtrl"/>
            </Border>
        </Grid>
    </Grid>
</UserControl>