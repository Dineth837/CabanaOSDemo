<UserControl x:Class="CabanaOSDemo.Views.RestaurantSalesPieChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="180" Height="180"
             HorizontalAlignment="Center" 
             VerticalAlignment="Center">
    <Grid>
        <TextBlock Text="Restaurant &amp; Reservations Sales" FontSize="12" FontWeight="Bold" Foreground="#1E293B" HorizontalAlignment="Center" VerticalAlignment="Top"/>

        <Viewbox Margin="0,20,0,0">
            <Canvas Width="200" Height="200">

                <Path Fill="#FEF3C7" Data="M100,100 L47.1,27.2 A90,90 0 0,1 172.8,47.1 Z">
                    <Path.RenderTransform>
                        <TranslateTransform X="0" Y="-5"/>
                    </Path.RenderTransform>
                </Path>

                <Path Fill="#BBF7D0" Data="M100,100 L172.8,47.1 A90,90 0 0,1 190,100 Z">
                    <Path.RenderTransform>
                        <TranslateTransform X="5" Y="-2"/>
                    </Path.RenderTransform>
                </Path>

                <Path Fill="#FDE047" Data="M100,100 L190,100 A90,90 0 0,1 47.1,172.8 Z">
                    <Path.RenderTransform>
                        <TranslateTransform X="3" Y="5"/>
                    </Path.RenderTransform>
                </Path>

                <Path Fill="#22C55E" Data="M100,100 L47.1,172.8 A90,90 0 0,1 47.1,27.2 Z">
                    <Path.RenderTransform>
                        <TranslateTransform X="-5" Y="0"/>
                    </Path.RenderTransform>
                </Path>

                <TextBlock x:Name="LblDeluxeFamily" Text="30%&#x0a;Deluxe Family" FontSize="8" FontWeight="Bold" Foreground="#1E293B" Canvas.Left="83" Canvas.Top="34" TextAlignment="Center"/>
                <TextBlock x:Name="LblStandardFamily" Text="15%&#x0a;Standard Family" FontSize="8" FontWeight="Bold" Foreground="#1E293B" Canvas.Left="129" Canvas.Top="73" TextAlignment="Center"/>
                <TextBlock x:Name="LblDeluxeCouple" Text="35%&#x0a;Deluxe&#x0a;Couple" FontSize="8" FontWeight="Bold" Foreground="#1E293B" Canvas.Left="113" Canvas.Top="125" TextAlignment="Center"/>
                <TextBlock x:Name="LblStandardCouple" Text="20%&#x0a;Standard&#x0a;Couple" FontSize="8" FontWeight="Bold" Foreground="#1E293B" Canvas.Left="28" Canvas.Top="84" TextAlignment="Center"/>

            </Canvas>
        </Viewbox>
    </Grid>
</UserControl>