<UserControl x:Class="CabanaOSDemo.Views.SuiteBillingSummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <StackPanel Margin="5">
        <TextBlock Text="Room Management &amp; Billing" FontFamily="{StaticResource PrimaryHeadingFont}" FontSize="18" Foreground="#F8FAFC" FontWeight="Bold" Margin="0,5,0,15"/>

        <Border Background="#F1F5F9" CornerRadius="12" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Active Occupant Status" FontSize="10" Foreground="#64748B"/>
                <TextBlock x:Name="TxtCustomerName" Text="Customer Name" FontSize="14" Foreground="#0F172A" FontWeight="Bold" Margin="0,2,0,8"/>
                <TextBlock x:Name="TxtSuiteBookedLabel" Text="Standard Suite Occupied" FontSize="11" Foreground="#475569"/>
            </StackPanel>
        </Border>

        <UniformGrid Columns="2" Margin="0,0,0,15">
            <Border Background="#F1F5F9" CornerRadius="12" Padding="12" Margin="0,0,5,0">
                <StackPanel>
                    <TextBlock Text="Room Number" FontSize="10" Foreground="#64748B"/>
                    <TextBlock x:Name="TxtRoomNumber" Text="RM 000" FontSize="14" Foreground="#0F172A" FontWeight="Bold"/>
                </StackPanel>
            </Border>
            <Border Background="#F1F5F9" CornerRadius="12" Padding="12" Margin="5,0,0,0">
                <StackPanel>
                    <TextBlock Text="Category" FontSize="10" Foreground="#64748B"/>
                    <TextBlock x:Name="TxtCategory" Text="Standard Suite" FontSize="13" Foreground="#0F172A" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border Background="#F1F5F9" CornerRadius="12" Padding="15" Margin="0,0,0,25">
            <StackPanel>
                <TextBlock Text="Accommodation Ledger Breakdown" FontSize="11" Foreground="#0F172A" FontWeight="Bold" Margin="0,0,0,10"/>

                <Grid Margin="0,4">
                    <TextBlock Text="Accommodation (Stay Base)" FontSize="11" Foreground="#475569"/>
                    <TextBlock x:Name="TxtBaseCharge" Text="Rs. 00.00" FontSize="11" Foreground="#0F172A" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,4">
                    <TextBlock Text="Restaurant / Room Service" FontSize="11" Foreground="#475569"/>
                    <TextBlock x:Name="TxtRoomServiceCharge" Text="Rs. 00.00" FontSize="11" Foreground="#0F172A" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,4">
                    <TextBlock Text="Tax &amp; Hospitality Levies" FontSize="11" Foreground="#475569"/>
                    <TextBlock x:Name="TxtTaxCharge" Text="Rs. 00.00" FontSize="11" Foreground="#0F172A" HorizontalAlignment="Right"/>
                </Grid>

                <Separator Background="#CBD5E1" Margin="0,10"/>

                <Grid>
                    <TextBlock Text="Total Outstanding Due" FontSize="12" Foreground="#0F172A" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtTotalDue" Text="Rs. 00.00" FontSize="13" Foreground="#0F172A" FontWeight="Bold" HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </Border>

        <UniformGrid Columns="2">
            <Button x:Name="BtnSettleDue" Content="Settle Due" Background="#A7F3D0" Foreground="#065F46" Height="40" FontWeight="Bold" Margin="5" Click="BtnSettleDue_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="12"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button x:Name="BtnReleaseRoom" Content="Release Room" Background="#A7F3D0" Foreground="#065F46" Height="40" FontWeight="Bold" Margin="5" Click="BtnReleaseRoom_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="12"/>
                    </Style>
                </Button.Resources>
            </Button>
        </UniformGrid>
    </StackPanel>
</UserControl>