<Window x:Class="CabanaOSDemo.Views.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Report Generator" 
        Height="480
        " Width="350"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        WindowStartupLocation="CenterOwner">

    <Border Background="#0F162B" CornerRadius="20" Padding="20">
        <StackPanel>
            <StackPanel.Resources>
                <Style x:Key="ReportButtonStyle" TargetType="Button">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Setter Property="Height" Value="50"/>
                    <Setter Property="Width" Value="255"/>
                    <Setter Property="Margin" Value="0,10"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="20">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="border" Property="Background" Value="#E5D6C5"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </StackPanel.Resources>

            <Button Content="✕" Foreground="#F8FAFC" Background="Transparent" BorderThickness="0" 
                    HorizontalAlignment="Right" Click="Close_Click" FontWeight="Bold" Margin="0,0,0,20"/>

            <TextBlock Text="Report Generator" Foreground="White" FontSize="24" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <Button Style="{StaticResource ReportButtonStyle}" Content="Monthly Revenue Summary" Click="BtnMonthly_Click"/>
            <Button Style="{StaticResource ReportButtonStyle}" Content="Daily Transactions" Click="BtnDaily_Click"/>
            <Button Style="{StaticResource ReportButtonStyle}" Content="Customer Report" Click="BtnCustomer_Click"/>
            <Button Style="{StaticResource ReportButtonStyle}" Content="Employee Report" Click="BtnEmployee_Click"/>
        </StackPanel>
    </Border>
</Window>