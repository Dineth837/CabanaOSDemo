<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" mc:Ignorable="d" x:Class="CabanaOSDemo.Views.InvoiceArchivedView"
             d:DesignWidth="235.073">

    <StackPanel Margin="5">
        <TextBlock x:Name="TxtHeaderTitle" Text="Archived Invoice" FontFamily="{StaticResource PrimaryHeadingFont}" FontSize="18" Foreground="#F8FAFC" FontWeight="Bold" Margin="0,5,0,15"/>

        <Border Background="#1E293B" CornerRadius="12" Padding="12" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Account Identifier / Number" FontSize="10" Foreground="#94A3B8"/>
                <TextBlock x:Name="TxtIdentifier" Text="ST C08" FontSize="14" Foreground="White" FontWeight="Bold" Margin="0,2,0,8"/>

                <TextBlock Text="Account Category Type" FontSize="10" Foreground="#94A3B8"/>
                <TextBlock x:Name="TxtCategory" Text="Standard Zone" FontSize="13" Foreground="#CBD5E1" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <Border Background="#1E293B" CornerRadius="12" Padding="15" Margin="0,0,0,25">
            <StackPanel>
                <TextBlock Text="Settled Bill Ledger Breakdown" FontSize="11" Foreground="#94A3B8" FontWeight="Bold" Margin="0,0,0,10"/>

                <Grid Margin="0,4">
                    <TextBlock Text="Total Gross Base Volume" FontSize="11" Foreground="#94A3B8"/>
                    <TextBlock x:Name="TxtGrossVolume" Text="Rs. 00.00" FontSize="11" Foreground="#F1F5F9" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,4">
                    <TextBlock Text="System Tax &amp; Service Levies" FontSize="11" Foreground="#94A3B8"/>
                    <TextBlock Text="Rs. 00.00" FontSize="11" Foreground="#F1F5F9" HorizontalAlignment="Right"/>
                </Grid>

                <Separator Background="#334155" Margin="0,10"/>

                <Grid>
                    <TextBlock Text="Total Paid Statement" FontSize="12" Foreground="White" FontWeight="Bold"/>
                    <TextBlock x:Name="TxtFinalPaid" Text="Rs. 00.00" FontSize="13" Foreground="#22C55E" FontWeight="Bold" HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </Border>

        <UniformGrid Columns="2">
            <Button x:Name="BtnPrintInvoice" Content="Print Invoice" Background="#38BDF8" Foreground="#0C4A6E" Height="40" FontWeight="Bold" Margin="5" Click="BtnPrintInvoice_Click_1">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="12"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button x:Name="BtnClosePane" Content="Close" Background="#475569" Foreground="#F8FAFC" Height="40" Margin="5">
                <Button.Resources>
                    <Style TargetType="{x:Type Border}">
                        <Setter Property="CornerRadius" Value="12"/>
                    </Style>
                </Button.Resources>
            </Button>
        </UniformGrid>
    </StackPanel>
</UserControl>