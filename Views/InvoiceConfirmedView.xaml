<UserControl x:Class="CabanaOSDemo.Views.InvoiceConfirmedView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">
    <StackPanel>
        <TextBlock x:Name="TxtMainTitle" Text="🏩 Room Management" FontFamily="{StaticResource PrimaryHeadingFont}" FontSize="20" Foreground="#0F172A" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Border x:Name="BdrOccupantStatus" Background="#F0FDF4" CornerRadius="12" Padding="15" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="Active Occupant Status" FontSize="11" Foreground="#64748B"/>
                <TextBlock x:Name="TxtCusName" Text="Customer Name" FontWeight="Bold" FontSize="14" Margin="0,4,0,2"/>
                <TextBlock x:Name="TxtSuiteBookedLabel" Text="Standard Suite Booked" FontSize="11" Foreground="#475569"/>
            </StackPanel>
        </Border>

        <UniformGrid Columns="2" Margin="0,0,0,20">
            <Border x:Name="BdrRoomNumberBadge" Background="#F0FDF4" CornerRadius="12" Padding="10" Margin="5">
                <StackPanel>
                    <TextBlock Text="Room Number" FontSize="11" Foreground="#64748B"/>
                    <TextBlock x:Name="TxtInvoiceRoomNumber" Text="ST01" FontWeight="Bold" Foreground="#0F172A"/>
                </StackPanel>
            </Border>
            <Border x:Name="BdrCategoryBadge" Background="#F0FDF4" CornerRadius="12" Padding="10" Margin="5">
                <StackPanel>
                    <TextBlock Text="Category" FontSize="11" Foreground="#64748B"/>
                    <TextBlock x:Name="TxtInvoiceCategory" Text="Standard Suite" FontWeight="Bold" Foreground="#0F172A"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <Border x:Name="BdrInvoiceStatementCard" Background="#F0FDF4" BorderBrush="#E2E8F0"  CornerRadius="12" Padding="15">
            <StackPanel>
                <TextBlock x:Name="TxtInvoiceTitle" Text="Unified Invoice Balance" FontWeight="Bold" Foreground="#0F172A" Margin="0,0,0,10"/>

                <Grid Margin="0,4">
                    <TextBlock Text="Accommodation (1 Night)" FontSize="11" Foreground="#475569"/>
                    <TextBlock x:Name="TxtAccommodationCharge" Text="Rs. 8,500.00" HorizontalAlignment="Right" FontSize="11" Foreground="#0F172A"/>
                </Grid>

                <Grid Margin="0,4">
                    <TextBlock Text="Restaurant Charges" FontSize="11" Foreground="#475569"/>
                    <TextBlock Text="Rs. 00.00" HorizontalAlignment="Right" FontSize="11" Foreground="#0F172A"/>
                </Grid>

                <Grid Margin="0,4">
                    <TextBlock Text="Service Charges" FontSize="11" Foreground="#475569"/>
                    <TextBlock Text="Rs. 00.00" HorizontalAlignment="Right" FontSize="11" Foreground="#0F172A"/>
                </Grid>

                <Separator Background="#E2E8F0" Margin="0,10"/>

                <Grid>
                    <TextBlock x:Name="TxtDueTitle" Text="Total Statement Due" FontWeight="Bold" Foreground="#0F172A"/>
                    <TextBlock x:Name="TxtTotalStatementDue" Text="Rs. 8,500.00" HorizontalAlignment="Right" FontWeight="Bold" FontSize="12" Foreground="#0F172A"/>
                </Grid>
            </StackPanel>
        </Border>

        <UniformGrid Columns="2" Margin="0,25,0,0">
            <Button x:Name="BtnSettleDue" Content="Settle Due" Background="#A7F3D0" Foreground="#065F46" Height="40" Margin="5" Click="BtnSettleDue_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="12"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button x:Name="BtnReleaseRoom" Content="Release Room" Background="#A7F3D0" Foreground="#065F46" Height="40" Margin="5">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="12"/>
                    </Style>
                </Button.Resources>
            </Button>
        </UniformGrid>
    </StackPanel>
</UserControl>