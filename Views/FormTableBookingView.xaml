<UserControl x:Class="CabanaOSDemo.Views.FormTableBookingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Border Background="#FFFFFF" 
            CornerRadius="16" 
            Padding="16,20,16,20" 
            Margin="2">

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBlock x:Name="TxtTitle" Text="🏩 Reservations Management" FontSize="18" FontWeight="Bold" Foreground="#14532D" Margin="0,0,0,20"/>

                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="#F1F5F9" CornerRadius="10" Padding="12,10" Margin="0,0,6,0">
                            <StackPanel>
                                <TextBlock Text="Dining Zone" FontSize="10" FontWeight="Bold" Foreground="#64748B"/>
                                <TextBlock x:Name="TxtZoneLabel" Text="Standard Zone" FontSize="12" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Background="#F1F5F9" CornerRadius="10" Padding="12,10" Margin="6,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Table Type" FontSize="10" FontWeight="Bold" Foreground="#64748B"/>
                                <TextBlock x:Name="TxtTypeLabel" Text="Couple (2 Seats)" FontSize="12" FontWeight="SemiBold" Foreground="#1E293B" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Background="#F1F5F9" CornerRadius="10" Padding="15,14" Margin="0,0,0,20">
                        <Grid>
                            <TextBlock x:Name="TxtNumberLabel" Text="Table Number" FontSize="13" FontWeight="Bold" Foreground="#14532D" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtTableNumberLabel" Text="ST C01" FontSize="15" FontWeight="Bold" Foreground="#14532D" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <Separator Background="#E2E8F0" Margin="0,4,0,16" Height="1"/>

                    <TextBlock Name="TxtRegTitle" Text="Guest Registration" FontSize="15" FontWeight="Bold" Foreground="#1E293B" Margin="0,0,0,14"/>

                    <TextBlock Text="Lead Guest Name" FontSize="11" FontWeight="SemiBold" Foreground="#475569" Margin="2,0,0,6"/>
                    <TextBox x:Name="TxtLeadGuestName" 
                             Height="38" 
                             Background="#F1F5F9" 
                             Foreground="#1E293B"
                             FontWeight="Medium"
                             FontSize="13"
                             Padding="12,0,12,0"
                             VerticalContentAlignment="Center"
                             BorderThickness="0" 
                             Margin="0,0,0,14" 
                             TextChanged="TxtLeadGuestName_TextChanged">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock Text="Lead Guest NIC" FontSize="11" FontWeight="SemiBold" Foreground="#475569" Margin="2,0,0,6"/>
                    <TextBox x:Name="TxtLeadGuestNIC" 
                             Height="38" 
                             Background="#F1F5F9" 
                             Foreground="#1E293B"
                             FontWeight="Medium"
                             FontSize="13"
                             Padding="12,0,12,0"
                             VerticalContentAlignment="Center"
                             BorderThickness="0" 
                             Margin="0,0,0,14">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <TextBlock x:Name="TxtTotalGuestHeader" Text="Number of Total Guests" FontSize="11" FontWeight="SemiBold" Foreground="#475569" Margin="2,0,0,6" Visibility="Collapsed"/>
                    <TextBox x:Name="TxtTotalGuestInput" 
                             Height="38" 
                             Background="#F1F5F9" 
                             Foreground="#1E293B"
                             FontWeight="Medium"
                             FontSize="13"
                             Padding="12,0,12,0"
                             VerticalContentAlignment="Center"
                             BorderThickness="0" 
                             Margin="0,0,0,14" 
                             Visibility="Collapsed">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="1" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="BtnConfirm" 
                        Content="Confirm &amp; Reserve" 
                        Click="BtnConfirm_Click" 
                        Grid.Column="0" 
                        Height="40" 
                        Background="#101827"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        FontWeight="Bold" 
                        FontSize="11" 
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Button x:Name="BtnCancel" 
                        Content="Cancel" 
                        Grid.Column="1" 
                        Height="40" 
                        Margin="8,0,0,0"
                        Background="#F1F5F9" 
                        Foreground="#475569" 
                        BorderThickness="0" 
                        FontWeight="Bold" 
                        FontSize="11" 
                        Cursor="Hand" Click="BtnCancel_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>