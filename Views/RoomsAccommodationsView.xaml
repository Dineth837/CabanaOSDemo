<UserControl x:Class="CabanaOSDemo.Views.RoomsAccommodationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9">

    <UserControl.Resources>
        <Style x:Key="RoomCardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#F0FDF4"/>
            <Setter Property="BorderBrush" Value="#86EFAC"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Height" Value="95"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="20,12,15,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Resources>
                <Style TargetType="Border">
                    <Setter  Property="CornerRadius" Value="16"/>
                </Style>
            </Style.Resources>
        </Style>

        <Style x:Key="ReservedRoomCardStyle" TargetType="Button" BasedOn="{StaticResource RoomCardButtonStyle}">
            <Setter Property="Background" Value="#FEF2F2"/>
            <Setter Property="BorderBrush" Value="#FCA5A5"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10,0,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="🛎️ Room &amp; Accommodations" 
                   FontFamily="{StaticResource PrimaryHeadingFont}" 
                   FontSize="26" 
                   Foreground="#1E293B" 
                   FontWeight="Bold" 
                   Margin="0,0,0,15"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380"/>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <Button x:Name="BtnStandardTier" Content="Standard Suites" Click="TierFilterButton_Click" Background="#111827" Foreground="White" FontFamily="{StaticResource PrimaryHeadingFont}" FontSize="11" FontWeight="Bold" Padding="12,6" Margin="0,0,6,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="BtnSuperiorTier" Content="Superior Suites" Click="TierFilterButton_Click" Background="#E2E8F0" Foreground="#1E293B" FontFamily="{StaticResource PrimaryHeadingFont}" FontSize="11" FontWeight="Bold" Padding="10,6" Margin="0,0,6,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="BtnDeluxeTier" Content="Deluxe Suites" Click="TierFilterButton_Click" Background="#E2E8F0" Foreground="#1E293B" FontFamily="{StaticResource PrimaryHeadingFont}" FontSize="11" FontWeight="Bold" Padding="10,6">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                    <UniformGrid x:Name="RoomsGridMatrixDisplay" Columns="2" HorizontalAlignment="Stretch">
                    </UniformGrid>
                </ScrollViewer>
            </Grid>

            <Border x:Name="BdrMiddleShowcaseCard" Grid.Column="1"  BorderThickness="1.5" CornerRadius="16" Background="#F8FAFC" Margin="0,0,15,0" Padding="12">
                <StackPanel>
                    <Border CornerRadius="12" Height="140" ClipToBounds="True" Background="#E2E8F0">
                        <Image x:Name="ImgRoomShowcase" Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock x:Name="TxtMiddleSuiteTitle" Text="Standard Tier Suites" FontFamily="{StaticResource PrimaryHeadingFont}" FontSize="16" Foreground="#065F46" FontWeight="Bold" Margin="0,15,0,8"/>
                    <TextBlock x:Name="TxtMiddleSuiteDescription" Text="Our Standard Suite Collection masterfully synthesizes modern minimalism with refined comfort. Flooded with natural light, these curated havens balance restorative rest with understated utility, offering the perfect backdrop for your stay."
                               TextWrapping="Wrap" FontFamily="{StaticResource SecondaryBodyFont}" FontSize="10" Foreground="#065F46" LineHeight="14"/>
                    <Separator Margin="0,15,0,10" Background="#E2E8F0"/>

                    <TextBlock Text="Prices" FontFamily="{StaticResource PrimaryHeadingFont}" FontSize="14" Foreground="#334155" FontWeight="Bold" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtMiddleFamilyPrice" Text="Family Package: Rs. 15,000 / night" FontFamily="{StaticResource SecondaryBodyFont}" FontSize="10" Foreground="#475569" Margin="0,2"/>
                    <TextBlock x:Name="TxtMiddleCouplePrice" Text="Couple Package: Rs. 8,500 / night" FontFamily="{StaticResource SecondaryBodyFont}" FontSize="10" Foreground="#475569"/>
                </StackPanel>
            </Border>
        
            <Border Grid.Column="2" Background="#F8FAFC" CornerRadius="20" Padding="20" Margin="0">
                <Grid>
                    <ContentControl x:Name="DynamicFormWorkspace"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>