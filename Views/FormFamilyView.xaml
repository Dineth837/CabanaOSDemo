<UserControl x:Class="CabanaOSDemo.Views.FormFamilyView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent" Loaded="UserControl_Loaded">
    <StackPanel>
        <TextBlock x:Name="TxtTitle" Text="🛎️ Room Management" FontFamily="{StaticResource PrimaryHeadingFont}" FontSize="20" Foreground="#065F46" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <UniformGrid Columns="2" Margin="0,0,0,15">
            <StackPanel Margin="5">
                <TextBlock Text="Room Type" FontSize="11" Foreground="#64748B"/>
                <TextBlock x:Name="TxtRoomPackageTitle" Text="Standard Suite | Family" Foreground="#065F46" FontWeight="Bold" FontSize="13"/>
            </StackPanel>
            <StackPanel Margin="5">
                <TextBlock Text="Cost / night" FontSize="11" Foreground="#64748B"/>
                <TextBlock x:Name="TxtCostPerNight" Foreground="#065F46" Text="Rs. 15,000.00" FontWeight="Bold" FontSize="13"/>
            </StackPanel>
        </UniformGrid>

        <TextBlock Text="Room Number" FontSize="11" Foreground="#64748B"/>
        <TextBox x:Name="TxtRoomNumberDisplayBox" Style="{StaticResource CabanaPillTextBox}" Text="" IsReadOnly="True" Margin="0,4,0,15"/>

        <TextBlock x:Name="TxtRegTitle" Foreground="#065F46"  Text="Guest Registration" FontFamily="{StaticResource PrimaryHeadingFont}" FontSize="16" FontWeight="Bold" Margin="0,5,0,15"/>
        <TextBlock Text="Lead Guest Name" FontSize="11" Foreground="#64748B"/>
        <TextBox x:Name="txtLeadGuestName" Style="{StaticResource CabanaPillTextBox}" Margin="0,4,0,12"/>
        
        <TextBlock Text="Lead Guest NIC" FontSize="11" Foreground="#64748B"/>
        <TextBox x:Name="txtLeadGuestNIC" Style="{StaticResource CabanaPillTextBox}" Margin="0,4,0,12"/>
        
        <TextBlock Text="Number of total Guest" FontSize="11" Foreground="#64748B"/>
        <TextBox x:Name="txtGuestCount" Style="{StaticResource CabanaPillTextBox}" Margin="0,4,0,25"/>

        <UniformGrid Columns="2">
            <Button x:Name="BtnConfirm" 
                Content="Confirm &amp; Book In" 
                Click="BtnConfirm_Click" 
                Grid.Column="0" 
                Height="40" 
                Background="#A7F3D0" 
                Foreground="#065F46"
                BorderThickness="0"
                FontWeight="Bold" 
                FontSize="11" 
                Cursor="Hand">  
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button x:Name="BtnCancle" 
                Content="Cancel" 
                Grid.Column="1" 
                Height="40" 
                Margin="8,0,0,0"
                Background="#FCA5A5" 
                Foreground="#991B1B"
                BorderThickness="0" 
                FontWeight="Bold" 
                FontSize="11" 
                Cursor="Hand" 
                Click="BtnCancle_Click">  
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </UniformGrid>
    </StackPanel>
</UserControl>