<UserControl x:Class="CabanaOSDemo.Views.DefaultWelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,0,100,0">
        <StackPanel HorizontalAlignment="Center">

            <TextBlock Text="CabanaOS" 
                       Foreground="#1E293B" 
                       FontSize="90" 
                       FontWeight="Bold" 
                       FontFamily="Segoe UI, Arial"
                       FontStretch="UltraExpanded"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="Cabana &amp; Restaurant Management System" 
                       Foreground="#1E293B" 
                       FontSize="20" 
                       FontWeight="SemiBold" 
                       FontFamily="Segoe UI, Arial"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"
                       Opacity="0.9"/>

        </StackPanel>
    </Grid>
</UserControl>