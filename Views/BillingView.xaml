<UserControl x:Class="CabanaOSDemo.Views.BillingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9">

    <Grid Margin="10,0,10,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="💵 Master Auditing" 
                   FontFamily="{StaticResource PrimaryHeadingFont}" 
                   FontSize="26" 
                   Foreground="#1E293B" 
                   FontWeight="Bold" 
                   Margin="0,10,0,15"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
                    <Button x:Name="BtnToggleRestaurant" Content="Restaurant Reservations" Click="SubModuleFilter_Click" Background="#111827" Foreground="White" FontFamily="{StaticResource PrimaryHeadingFont}" FontSize="11" FontWeight="Bold" Padding="14,8" Margin="0,0,6,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="BtnToggleRooms" Content="Rooms &amp; Accommodations" Click="SubModuleFilter_Click" Background="#E2E8F0" Foreground="#1E293B" FontFamily="{StaticResource PrimaryHeadingFont}" FontSize="11" Padding="14,8">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,15">
                    <Border Background="#1E293B" CornerRadius="16" Height="100" Margin="0,0,8,0" Padding="15">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TxtKpiRevenueTitle" Text="Total Restaurant Revenue" FontFamily="{StaticResource PrimaryHeadingFont}" FontSize="11" Foreground="#94A3B8" FontWeight="Medium"/>
                            <TextBlock x:Name="TxtKpiRevenueDate" FontSize="8" Foreground="#64748B" Margin="0,2,0,8"/>
                            <TextBlock x:Name="TxtKpiRevenueValue" Text="Rs. Today Revenue . 00" FontFamily="{StaticResource SecondaryBodyFont}" FontSize="16" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1E293B" CornerRadius="16" Height="100" Margin="4,0,4,0" Padding="15">
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="TxtKpiDuesTitle" Text="Ongoing Order Due" FontFamily="{StaticResource PrimaryHeadingFont}" FontSize="11" Foreground="#94A3B8" FontWeight="Medium"/>
                            <TextBlock x:Name="TxtKpiDuesDate" FontSize="8" Foreground="#64748B" Margin="0,2,0,8"/>
                            <TextBlock x:Name="TxtKpiDuesValue" Text="Rs. Current Due . 00" FontFamily="{StaticResource SecondaryBodyFont}" FontSize="16" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#1E293B" CornerRadius="16" Height="100" Margin="8,0,0,0" Padding="15">
                        <StackPanel VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <Ellipse Width="6" Height="6" Fill="#22C55E" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtKpiAvailLabel" Text="10 Tables Available" FontFamily="{StaticResource SecondaryBodyFont}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <Ellipse Width="6" Height="6" Fill="#EF4444" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtKpiOccLabel" Text="6 Tables Occupied" FontFamily="{StaticResource SecondaryBodyFont}" FontSize="11" Foreground="White" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="2" Background="White" CornerRadius="16" Padding="10">
                    <DataGrid x:Name="DgdAuditLedger" 
                              SelectionChanged="DgdAuditLedger_SelectionChanged"
                              AutoGenerateColumns="False" 
                              IsReadOnly="True" 
                              Background="Transparent" 
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#E2E8F0"
                              RowHeight="42"
                              HeadersVisibility="Column"
                              CanUserAddRows="False">
                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#E2E8F0"/>
                                <Setter Property="Foreground" Value="#1E293B"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="Padding" Value="10,8"/>
                                <Setter Property="BorderThickness" Value="0"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>
                    </DataGrid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Background="#0F172A" CornerRadius="20" Padding="18">
                <Grid VerticalAlignment="Stretch">
                    <ContentControl x:Name="DynamicBillingWorkspace" 
                                    VerticalContentAlignment="Stretch" 
                                    HorizontalContentAlignment="Stretch"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>