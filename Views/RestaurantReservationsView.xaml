<UserControl x:Class="CabanaOSDemo.Views.RestaurantReservationsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F1F5F9">

    <Grid Margin="25,20,25,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="🏩 Restaurant &amp; Reservations" 
                   FontFamily="{StaticResource PrimaryHeadingFont}" 
                   FontSize="26" 
                   Foreground="#1E293B" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,20,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,25">
                    <Button x:Name="BtnStandardZone" Content="Standard Tier Zone" Click="ZoneFilterButton_Click" Background="#111827" Foreground="White" FontFamily="{StaticResource PrimaryHeadingFont}" FontSize="11" FontWeight="Bold" Padding="14,6" Margin="0,0,8,0">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="BtnDeluxeZone" Content="Deluxe Tier Zone" Click="ZoneFilterButton_Click" Background="#E2E8F0" Foreground="#1E293B" FontFamily="{StaticResource PrimaryHeadingFont}" FontWeight="Bold" FontSize="11" Padding="14,6">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>

                <Border Grid.Row="1" Background="Transparent" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid x:Name="GridFloorLayoutContentArea" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"/>
                </Border>
            </Grid>

            <Border Grid.Column="1" Background="Transparent" CornerRadius="0" Padding="0">
                <ContentControl x:Name="DynamicReservationWorkspace" />
            </Border>
        </Grid>
    </Grid>
</UserControl>