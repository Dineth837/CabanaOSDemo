<UserControl x:Class="CabanaOSDemo.Views.MonthlySalesBarChart"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="25,20,25,15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="Monthly Sales Performance" FontSize="16" FontWeight="Bold" Foreground="#1E293B" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Ellipse Width="12" Height="12" Fill="#1D4ED8" Margin="0,0,6,0"/>
                <TextBlock Text="Restaurant" FontSize="13" Foreground="#475569" Margin="0,0,20,0" FontWeight="SemiBold"/>
                <Ellipse Width="12" Height="12" Fill="#06B6D4" Margin="0,0,6,0"/>
                <TextBlock Text="Suites" FontSize="13" Foreground="#475569" FontWeight="SemiBold"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="50,10,10,0" Height="150">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Column="0" Grid.Row="0" Text="500,000" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,-6,10,0"/>
            <TextBlock Grid.Column="0" Grid.Row="1" Text="400,000" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,-6,10,0"/>
            <TextBlock Grid.Column="0" Grid.Row="2" Text="300,000" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,-6,10,0"/>
            <TextBlock Grid.Column="0" Grid.Row="3" Text="200,000" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,-6,10,0"/>
            <TextBlock Grid.Column="0" Grid.Row="4" Text="100,000" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,-6,10,0"/>
            <TextBlock Grid.Column="0" Grid.Row="4" Text="0" FontSize="10" Foreground="#94A3B8" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,10,-6"/>

            <Border Grid.Column="1" Grid.Row="0" BorderBrush="#F1F5F9" BorderThickness="0,1,0,0" VerticalAlignment="Top"/>
            <Border Grid.Column="1" Grid.Row="0" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
            <Border Grid.Column="1" Grid.Row="1" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
            <Border Grid.Column="1" Grid.Row="2" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
            <Border Grid.Column="1" Grid.Row="3" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>
            <Border Grid.Column="1" Grid.Row="4" BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" VerticalAlignment="Bottom"/>

            <UniformGrid Grid.Column="1" Grid.Row="0" Grid.RowSpan="5" Columns="12" VerticalAlignment="Bottom" Height="150">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10,0">
                    <Border x:Name="BarJanRest" Width="12" Height="140" Background="#1D4ED8" CornerRadius="6,6,0,0" Margin="0,0,4,0" VerticalAlignment="Bottom"/>
                    <Border x:Name="BarJanSuite" Width="12" Height="70" Background="#06B6D4" CornerRadius="6,6,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10,0">
                    <Border x:Name="BarFebRest" Width="12" Height="100" Background="#1D4ED8" CornerRadius="6,6,0,0" Margin="0,0,4,0" VerticalAlignment="Bottom"/>
                    <Border x:Name="BarFebSuite" Width="12" Height="35" Background="#06B6D4" CornerRadius="6,6,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10,0">
                    <Border x:Name="BarMarRest" Width="12" Height="90" Background="#1D4ED8" CornerRadius="6,6,0,0" Margin="0,0,4,0" VerticalAlignment="Bottom"/>
                    <Border x:Name="BarMarSuite" Width="12" Height="75" Background="#06B6D4" CornerRadius="6,6,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10,0">
                    <Border x:Name="BarAprRest" Width="12" Height="140" Background="#1D4ED8" CornerRadius="6,6,0,0" Margin="0,0,4,0" VerticalAlignment="Bottom"/>
                    <Border x:Name="BarAprSuite" Width="12" Height="110" Background="#06B6D4" CornerRadius="6,6,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10,0">
                    <Border x:Name="BarMayRest" Width="12" Height="40" Background="#1D4ED8" CornerRadius="6,6,0,0" Margin="0,0,4,0" VerticalAlignment="Bottom"/>
                    <Border x:Name="BarMaySuite" Width="12" Height="70" Background="#06B6D4" CornerRadius="6,6,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10,0">
                    <Border x:Name="BarJunRest" Width="12" Height="115" Background="#1D4ED8" CornerRadius="6,6,0,0" Margin="0,0,4,0" VerticalAlignment="Bottom"/>
                    <Border x:Name="BarJunSuite" Width="12" Height="70" Background="#06B6D4" CornerRadius="6,6,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10,0">
                    <Border x:Name="BarJulRest" Width="12" Height="118" Background="#1D4ED8" CornerRadius="6,6,0,0" Margin="0,0,4,0" VerticalAlignment="Bottom"/>
                    <Border x:Name="BarJulSuite" Width="12" Height="100" Background="#06B6D4" CornerRadius="6,6,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10,0">
                    <Border x:Name="BarAugRest" Width="12" Height="118" Background="#1D4ED8" CornerRadius="6,6,0,0" Margin="0,0,4,0" VerticalAlignment="Bottom"/>
                    <Border x:Name="BarAugSuite" Width="12" Height="100" Background="#06B6D4" CornerRadius="6,6,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10,0">
                    <Border x:Name="BarSepRest" Width="12" Height="118" Background="#1D4ED8" CornerRadius="6,6,0,0" Margin="0,0,4,0" VerticalAlignment="Bottom"/>
                    <Border x:Name="BarSepSuite" Width="12" Height="100" Background="#06B6D4" CornerRadius="6,6,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10,0">
                    <Border x:Name="BarOctRest" Width="12" Height="140" Background="#1D4ED8" CornerRadius="6,6,0,0" Margin="0,0,4,0" VerticalAlignment="Bottom"/>
                    <Border x:Name="BarOctSuite" Width="12" Height="110" Background="#06B6D4" CornerRadius="6,6,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10,0">
                    <Border x:Name="BarNovRest" Width="12" Height="40" Background="#1D4ED8" CornerRadius="6,6,0,0" Margin="0,0,4,0" VerticalAlignment="Bottom"/>
                    <Border x:Name="BarNovSuite" Width="12" Height="68" Background="#06B6D4" CornerRadius="6,6,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="10,0">
                    <Border x:Name="BarDecRest" Width="12" Height="105" Background="#1D4ED8" CornerRadius="6,6,0,0" Margin="0,0,4,0" VerticalAlignment="Bottom"/>
                    <Border x:Name="BarDecSuite" Width="12" Height="36" Background="#06B6D4" CornerRadius="6,6,0,0" VerticalAlignment="Bottom"/>
                </StackPanel>
            </UniformGrid>
        </Grid>

        <UniformGrid Grid.Row="2" Columns="12" Margin="95,0,10,0">
            <TextBlock Text="Jan" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center"/>
            <TextBlock Text="Feb" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center"/>
            <TextBlock Text="Mar" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center"/>
            <TextBlock Text="Apr" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center"/>
            <TextBlock Text="May" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center"/>
            <TextBlock Text="Jun" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center"/>
            <TextBlock Text="Jul" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center"/>
            <TextBlock Text="Aug" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center"/>
            <TextBlock Text="Sep" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center"/>
            <TextBlock Text="Oct" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center"/>
            <TextBlock Text="Nov" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center"/>
            <TextBlock Text="Dec" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Center"/>
        </UniformGrid>
    </Grid>
</UserControl>